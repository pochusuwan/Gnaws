{
    "id": "minecraft",
    "displayName": "Minecraft",
    "ec2": {
        "instanceType": "t3a.large",
        "minimumInstanceType": "t3a.medium",
        "storage": 8,
        "ports": [
            {
                "port": 25565,
                "protocol": "tcp"
            }
        ]
    },
    "supportServerCommand": true,
    "termsOfService": [
        {
            "name": "Minecraft EULA",
            "url": "https://aka.ms/MinecraftEULA",
            "type": "checkbox"
        }
    ],
    "messages": [
        {
            "type": "info",
            "text": "You're setting up a Vanilla server. For better performance and lower hosting costs, we recommend Minecraft - Paper, a highly optimized Minecraft server that is fully compatible with Vanilla worlds and clients. Note that new Minecraft versions may take longer to be supported on Paper."
        }
    ],
    "configurations": [
        {
            "id": "levelSeed",
            "type": "alphanumeric",
            "maxLength": 64,
            "displayName": "World Seed",
            "description": "The seed for the generated world. Leave empty for random seed.",
            "isCreationOnly": true
        },
        {
            "id": "isHardcore",
            "type": "boolean",
            "default": false,
            "displayName": "Hardcore",
            "description": "Enables hardcore mode.",
            "isCreationOnly": true
        },
        {
            "id": "viewDistance",
            "type": "numeric",
            "isIntegerOnly": true,
            "displayName": "View Distance",
            "description": "Server-side render distance in chunks. Higher values increase CPU and memory usage.",
            "minValue": 3,
            "maxValue": 32
        },
        {
            "id": "spawnProtection",
            "type": "numeric",
            "isIntegerOnly": true,
            "displayName": "Spawn Protection",
            "description": "Set spawn protection area. Set to 0 to disable.",
            "minValue": 0,
            "maxValue": 256
        }
    ]
}
