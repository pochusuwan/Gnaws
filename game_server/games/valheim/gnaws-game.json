{
    "id": "valheim",
    "displayName": "Valheim",
    "ec2": {
        "instanceType": "t3.medium",
        "minimumInstanceType": "t3.small",
        "storage": 12,
        "ports": [
            {
                "port": 2456,
                "protocol": "udp"
            },
            {
                "port": 2457,
                "protocol": "udp"
            },
            {
                "port": 2458,
                "protocol": "udp"
            }
        ]
    },
    "termsOfService": [
        {
            "name": "SteamCMD License Agreement",
            "url": "https://store.steampowered.com/subscriber_agreement/",
            "type": "checkbox"
        }
    ],
    "messages": [
        {
            "type": "info",
            "text": "First-time server startup may take up to 10 minutes to generate the world."
        }
    ],
    "configurations": [
        {
            "id": "serverName",
            "type": "alphanumeric",
            "minLength": 1,
            "maxLength": 20,
            "displayName": "Server Name",
            "description": "The name shown in the Valheim server browser."
        },
        {
            "id": "serverPassword",
            "type": "alphanumeric",
            "minLength": 5,
            "maxLength": 20,
            "displayName": "Password",
            "description": "Password required to join. Leave empty for no password. Minimum 5 characters."
        },
        {
            "id": "isPublic",
            "type": "boolean",
            "default": false,
            "displayName": "Public",
            "description": "When enabled, the server appears in the public server browser. When disabled, it's hidden and only joinable via direct IP."
        }
    ]
}
