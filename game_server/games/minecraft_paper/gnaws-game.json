{
    "id": "minecraft_paper",
    "displayName": "Minecraft - Paper",
    "ec2": {
        "instanceType": "t3a.medium",
        "minimumInstanceType": "t3a.small",
        "storage": 8,
        "ports": [
            {
                "port": 25565,
                "protocol": "tcp"
            }
        ]
    },
    "supportServerCommand": true,
    "termsOfService": [
        {
            "name": "Minecraft EULA",
            "url": "https://aka.ms/MinecraftEULA",
            "type": "checkbox"
        }
    ],
    "configurations": [
        {
            "id": "levelSeed",
            "type": "alphanumeric",
            "maxLength": 64,
            "displayName": "World Seed",
            "description": "The seed for the generated world. Leave empty for random seed.",
            "isCreationOnly": true
        },
        {
            "id": "isHardcore",
            "type": "boolean",
            "default": false,
            "displayName": "Hardcore",
            "description": "Enables hardcore mode.",
            "isCreationOnly": true
        },
        {
            "id": "viewDistance",
            "type": "numeric",
            "isIntegerOnly": true,
            "displayName": "View Distance",
            "description": "Server-side render distance in chunks. Higher values increase CPU and memory usage. Leave empty for default.",
            "minValue": 3,
            "maxValue": 32
        },
        {
            "id": "spawnProtection",
            "type": "numeric",
            "isIntegerOnly": true,
            "displayName": "Spawn Protection",
            "description": "Set spawn protection area. Set to 0 to disable. Leave empty for default.",
            "minValue": 0,
            "maxValue": 256
        }
    ]
}
